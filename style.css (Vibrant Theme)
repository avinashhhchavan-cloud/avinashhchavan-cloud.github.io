body{
font-family: Arial;
background: linear-gradient(to right,#ff9966,#ff5e62);
color:white;
margin:0;
}

header{
background:#6a11cb;
padding:20px;
text-align:center;
}

nav{
background:#2575fc;
padding:10px;
text-align:center;
}

nav a{
color:white;
margin:15px;
font-weight:bold;
text-decoration:none;
}

section{
padding:30px;
background:rgba(0,0,0,0.3);
margin:20px;
border-radius:10px;
}

footer{
text-align:center;
padding:10px;
background:#000;
}

form{
width:300px;
margin:auto;
}

input,textarea{
width:100%;
margin:10px 0;
padding:8px;
}
